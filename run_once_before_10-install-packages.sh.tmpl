#!/usr/bin/env bash
set -euo pipefail

source_dir="{{ .chezmoi.sourceDir }}"

load_brew() {
    if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
}

if command -v apt >/dev/null 2>&1; then
    sudo apt update
    sudo apt install -y build-essential curl file git procps
    xargs -r sudo apt install -y <"$source_dir/packages/apt.txt"
fi

load_brew

if ! command -v brew >/dev/null 2>&1; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

load_brew

if ! command -v brew >/dev/null 2>&1; then
    printf '%s\n' 'Homebrew installation completed, but brew is not available on PATH.' >&2
    exit 1
fi

brew bundle --file "$source_dir/Brewfile"
