#!/usr/bin/env bash
set -euo pipefail

if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv bash)"
elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv bash)"
fi

if command -v mise >/dev/null 2>&1; then
    mise install
else
    printf '%s\n' 'mise is not available; package installation did not complete successfully.' >&2
    exit 1
fi

eval "$(mise activate bash)"

if command -v npm >/dev/null 2>&1; then
    xargs -r npm install -g <"{{ .chezmoi.sourceDir }}/packages/npm.txt"
else
    printf '%s\n' 'npm is not available after mise install; Node installation did not complete successfully.' >&2
    exit 1
fi
